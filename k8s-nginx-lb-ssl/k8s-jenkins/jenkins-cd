@Library('Shared') _
pipeline {
    agent {label 'jen-slave'}
    environment {
        GIT_USER_NAME = 'hemanthkuncha'
        GIT_USER_EMAIL = 'hemanthkuncha143@gmail.com'
    }
    
    parameters {
        string(name: 'FRONTEND_DOCKER_TAG', defaultValue: '', description: 'Frontend Docker tag of the image built by the CI job')
        string(name: 'BACKEND_DOCKER_TAG', defaultValue: '', description: 'Backend Docker tag of the image built by the CI job')
    }

    stages {
        stage("Workspace cleanup"){
            steps{
                script{
                    cleanWs()
                }
            }
        }
        
        stage('Git: Code Checkout') {
            steps {
                script{
                    code_checkout("https://github.com/hemanthkuncha/three-tier-app.git","main")
                }
            }
        }
        
        stage('Verify: Docker Image Tags') {
            steps {
                script{
                    echo "FRONTEND_DOCKER_TAG: ${params.FRONTEND_DOCKER_TAG}"
                    echo "BACKEND_DOCKER_TAG: ${params.BACKEND_DOCKER_TAG}"
                }
            }
        }
        
        stage("Update: Kubernetes manifests"){
            steps{
                script{
                    dir('k8s-nginx-lb-ssl/'){
                        sh """
                            sed -i -e s/three-tier-backend-ssl.*/three-tier-backend-ssl:${params.BACKEND_DOCKER_TAG}/g backend.yaml
                        """
                    }
                    
                    dir('k8s-nginx-lb-ssl/'){
                        sh """
                            sed -i -e s/three-tier-frontend-ssl.*/three-tier-frontend-ssl:${params.FRONTEND_DOCKER_TAG}/g frontend.yaml
                        """
                    }
                    
                }
            }
        }
        
        stage("Git: Code update and push to GitHub"){
            steps{
                script{
                    withCredentials([gitUsernamePassword(credentialsId: 'git-creds', gitToolName: 'git')]) {
                        sh '''
                        echo "Checking repository status: "
                        git status
                    
                        echo "Adding changes to git: "
                        git add .
                        
                        echo 'Configuring git user for commit: '
                        git config --global user.email "${GIT_USER_EMAIL}"
                        git config --global user.name "${GIT_USER_NAME}"
                    
                        echo "Commiting changes: "
                        git commit -m "Updated environment variables"
                        
                        echo "Pushing changes to github: "
                        git push https://github.com/hemanthkuncha/three-tier-app.git main
                    '''
                    }
                }
            }
        }
    }

  post {
        always {
            script {
                emailext attachLog: true,
                from: 'hemanthkuncha06@gmail.com',
                subject: "TWS Application has been updated and deployed - '${currentBuild.result}'",
                body: """
                    <html>
                    <body>
                        <div style="background-color: #FFA07A; padding: 10px; margin-bottom: 10px;">
                            <p style="color: black; font-weight: bold;">Project: ${env.JOB_NAME}</p>
                        </div>
                        <div style="background-color: #90EE90; padding: 10px; margin-bottom: 10px;">
                            <p style="color: black; font-weight: bold;">Build Number: ${params.BACKEND_DOCKER_TAG}</p>
                        </div>
                        <div style="background-color: #87CEEB; padding: 10px; margin-bottom: 10px;">
                            <p style="color: black; font-weight: bold;">URL: ${env.BUILD_URL}</p>
                        </div>
                    </body>
                    </html>
            """,
            to: 'hemanthkuncha06@gmail.com',
            mimeType: 'text/html'
            }
        }
    }
}
